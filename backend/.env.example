# Copy this file to .env and fill in real values. NEVER commit the real .env.

# Server
PORT=3002

# Allowed frontend origin for CORS (e.g. your Vercel URL). Optional in dev.
FRONTEND_URL=http://localhost:5173

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# JWT signing secret. Use a long, random value (e.g. `openssl rand -hex 32`).
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Auth cookie SameSite policy. Default "lax" works when the frontend and API
# share a site (including localhost). If they are deployed on different
# domains, set this to "none" (the cookie is then always marked Secure and
# requires HTTPS).
# COOKIE_SAMESITE=lax

# AWS S3 (only needed for the apnaGit push/pull CLI)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=your-bucket-name
